meta {
  name: Create Character
  type: http
  seq: 1
}

post {
  url: {{base_url}}/admin/characters
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "Runner",
    "default_unlocked": false,
    "rarity": "common",
    "metadata": {
      "sort_order": 1,
      "lore": "the original",
      "vfx": []
    }
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("character_id", res.body.id);
  }
}
