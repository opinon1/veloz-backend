meta {
  name: Delete Account
  type: http
  seq: 8
}

delete {
  url: {{base_url}}/auth/account
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "password": "securepassword123"
  }
}

script:post-response {
  if (res.status === 204) {
    bru.setEnvVar("access_token", "");
    bru.setEnvVar("refresh_token", "");
  }
}
