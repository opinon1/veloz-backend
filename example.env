DB_NAME=veloz_db
DB_USER=user
DB_PASSWORD=password
REDIS_PASSWORD=password
APP_PORT=81
POSTGRES_PORT=5432
REDIS_PORT=6379
# Rate limiting: set to false in beta/integ environments to disable the
# per-IP limiter on /auth/*. Leave unset or true in production.
RATE_LIMIT_ENABLED=true

# Etomin payment gateway. Leave EMAIL/PASSWORD unset to disable /payments/charge
# (it returns 503 when the client isn't configured).
ETOMIN_BASE_URL=https://pagos.etomin.com
ETOMIN_EMAIL=
ETOMIN_PASSWORD=
