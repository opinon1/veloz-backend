DB_NAME=veloz_db
DB_USER=user
DB_PASSWORD=password
REDIS_PASSWORD=password
APP_PORT=81
POSTGRES_PORT=5432
REDIS_PORT=6379
# Rate limiting: set to false in beta/integ environments to disable the
# per-IP limiter on /auth/*. Leave unset or true in production.
RATE_LIMIT_ENABLED=true

# Etomin payment gateway. Leave EMAIL/PASSWORD unset to disable /payments/charge
# (it returns 503 when the client isn't configured).
ETOMIN_BASE_URL=https://pagos.etomin.com
ETOMIN_EMAIL=jeetpstudios@etomin.com
ETOMIN_PASSWORD=Etomin123!

# Transactional email (SQS queue + SES sender). Leave SQS_EMAIL_QUEUE_URL
# unset to disable the mailer + worker (local dev). When set, AWS creds are
# resolved from the standard provider chain (task IAM role in prod).
# SQS_EMAIL_QUEUE_URL=https://sqs.us-west-1.amazonaws.com/346481751619/veloz-emails
# EMAIL_FROM=noreply@velozthegame.com
# EMAIL_SUPPORT_ADDR=soporte@velozthegame.com   # support mailto in receipt footer
# EMAIL_CTA_URL=https://velozthegame.com         # "back to game" link in receipt
# AWS_REGION=us-west-1
# SES_REGION=us-west-1   # optional; defaults to AWS_REGION

# Stats dashboard (/admin/stats): no config needed. The read-only stats pool
# reuses the app DB credentials and SET ROLE veloz_stats (a NOLOGIN SELECT-only
# role created by migration 0023) per session. Auto-enabled once migrations run.
